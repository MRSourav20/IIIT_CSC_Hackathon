{
    "manifest_version": 3,
    "name": "AntiGravity AI Co-Pilot",
    "version": "1.0",
    "description": "AI Assistant for government portals and CSC operators.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "styles_v3.css"
            ],
            "js": [
                "encryption.js",
                "steganography.js",
                "backup_engine.js",
                "speech_capture.js",
                "voice_player.js",
                "voice_assistant.js",
                "form_monitor.js",
                "validation_engine.js",
                "api_client.js",
                "field_mapper.js",
                "autofill_engine.js",
                "ocr_mock_engine.js",
                "document_classifier.js",
                "parsers/aadhaar_parser.js",
                "parsers/pan_parser.js",
                "parsers/certificate_parser.js",
                "form_state_tracker.js",
                "mutation_form_watcher.js",
                "ui_panel_v3.js",
                "govv_v3.js"
            ],
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["assets/panda.png", "page_state_hook.js"],
            "matches": ["<all_urls>"]
        }
    ]
}